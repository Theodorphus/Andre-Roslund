# Resend (kontaktformuläret) – skapa nyckel på resend.com/api-keys
RESEND_API_KEY="re_din_nyckel_har"
# Avsändaradress – måste tillhöra en verifierad domän i Resend, t.ex. kontakt@dindoman.se
CONTACT_FROM_EMAIL="kontakt@dindoman.se"

# Sanity – fyll i från sanity.io/manage efter att projektet skapats
NEXT_PUBLIC_SANITY_PROJECT_ID="din-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-10-01"

# Endast för seed-scriptet (node scripts/seed.mjs). Skapa i sanity.io/manage
# → API → Tokens, behörighet "Editor". Ska INTE läggas i Vercel.
SANITY_API_WRITE_TOKEN="ditt-write-token"
